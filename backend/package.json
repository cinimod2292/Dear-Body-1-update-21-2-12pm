    "bcryptjs": "^2.4.3",
    "dotenv": "^17.0.1",
    "fastify": "^5.3.2",
    "pino-pretty": "^13.0.0",
    "zod": "^4.1.5",
    "fastify-plugin": "^5.0.1"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "prisma": "^6.7.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.2"
  }
